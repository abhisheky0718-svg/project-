<%- layout('layouts/boilerplate') %>


  <style>
    #filters {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      overflow-x: auto;
    }
    /* Hide scrollbar for a cleaner look */
    #filters::-webkit-scrollbar {
      display: none;
    }
    .filter-link {
      text-decoration: none;
      color: inherit;
    }
    .filter-link:hover {
      color: inherit;
    }
    .filter {
      text-align: center;
      margin-right: 2rem;
      margin-top: 2rem; 
      opacity: 0.7;
      transition: all 0.2s ease;
      flex: 0 0 auto;
      padding-bottom: 5px;
      border-bottom: 2px solid transparent;
    }
    .filter:hover, .filter.active {
      opacity: 1;
      cursor: pointer;
      transform: scale(1.05);
      border-bottom: 2px solid #fe424d;
    }
    .filter p {
      font-size: 0.8rem;
      margin-bottom: 0;
    }
    .tax-toggle {
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: 1rem;
      padding: 0.8rem 1rem;
      margin-left: auto;
      margin-top: 2rem;
      display: flex;
      align-items: center;
      flex: 0 0 auto;
    }
  </style> 

    <% const activeCat = locals.activeCategory || "" %>

    <div id="filters">

      <a href="/listings<%= activeCat === 'Trending' ? '' : '?category=Trending' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Trending' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-fire"> </i></div>
          <p>Trending</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Room' ? '' : '?category=Room' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Room' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-bed"> </i></div>
          <p>Room</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Iconic Cities' ? '' : '?category=Iconic Cities' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Iconic Cities' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-mountain-city"> </i></div>
          <p>Iconic Cities</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Mountain' ? '' : '?category=Mountain' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Mountain' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-mountain"> </i></div>
          <p>Mountain</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Castels' ? '' : '?category=Castels' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Castels' ? 'active' : '' %>">
          <div> <i class="fa-brands fa-fort-awesome"> </i></div>
          <p>Castels</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Pools' ? '' : '?category=Pools' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Pools' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-person-swimming"> </i></div>
          <p>Pools</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Camping' ? '' : '?category=Camping' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Camping' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-campground"> </i></div>
          <p>Camping</p> 
        </div>
      </a>

      <a href="/listings<%= activeCat === 'Farms' ? '' : '?category=Farms' %>" class="filter-link">
        <div class="filter <%= activeCat === 'Farms' ? 'active' : '' %>">
          <div> <i class="fa-solid fa-cow"> </i></div>
          <p>Farms</p> 
        </div>
      </a>

      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input
           class="form-check-input" 
           type="checkbox" 
           role="switch" 
           id="flexswitchCheckDefault"/>
          <label class="form-check-label" for="flexswitchCheckDefault">Display Taxes </label>
        </div>
      </div>

    </div>
     <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings) { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link d-block">
            <div class="card listing-card">
              <img
            src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60' %>"
            class="card-img-top"
            alt="listing_image"
            style="height: 20rem"
             />
              <div class="card-img-overlay"></div>
              <div class="card-body">
                <p class="card-text">
                  <b><%= listing.title %></b> <br/>
                
                &#8377; <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
               <i class="tax-info"> &nbsp; &nbsp;+18% GST</i> 
              </p>
              </div>
            </div>
          </a>
        </div>
        <% } %>
     </div>
<script>
  const taxSwitch = document.getElementById("flexswitchCheckDefault");
  if (taxSwitch) {
    const taxInfoElements = document.querySelectorAll(".tax-info");
    taxSwitch.addEventListener("change", () => {
      const displayValue = taxSwitch.checked ? "inline" : "none";
      taxInfoElements.forEach((info) => {
        info.style.display = displayValue;
      });
    });
  }
</script>
  
